@page "/"

<div class="shikaku-page">
    <main class="game-shell" style="--cols:@Board.ColsNumber; --rows:@Board.RowsNumber">
        <section class="control-bar" aria-label="Ustawienia gry">
            <label>
                Rozmiar
                <select @bind="SelectedBoardSizeKey">
                    @foreach (var size in BoardSizes)
                    {
                        <option value="@size.Key">@size.Label</option>
                    }
                </select>
            </label>

            <label>
                Trudność
                <select @bind="SelectedDifficultyKey">
                    @foreach (var difficulty in DifficultyLevels)
                    {
                        <option value="@difficulty.Key">@difficulty.Label</option>
                    }
                </select>
            </label>

            <button class="primary-action" type="button" @onclick="StartNewGame">Nowa</button>
            <button type="button" @onclick="CheckBoard">Sprawdź</button>
            <button type="button" @onclick="RevealOneRect">Podpowiedź</button>
            <button type="button" @onclick="ClearBoard">Wyczyść</button>
        </section>

        <section class="board-card" aria-label="Plansza Shikaku">
            <div class="shikaku-board">
                @foreach (var row in Board.Grid)
                {
                    foreach (var cell in row)
                    {
                        <button class="shikaku-cell @cell.CssClass"
                                type="button"
                                title="@cell.Title"
                                @onpointerdown="@(() => HandlePointerDown(cell))"
                                @onpointerenter="@(() => HandlePointerEnter(cell))"
                                @onpointerup="@(() => HandlePointerUp(cell))">
                            @if (cell.Clue is not null)
                            {
                                <span class="clue">@cell.Clue.Area</span>
                            }
                        </button>
                    }
                }

                @if (CurrentRect is not null)
                {
                    <div class="current-rect-label"
                         style="--rect-x:@CurrentRect.LeftUpCornerY; --rect-y:@CurrentRect.LeftUpCornerX; --rect-cols:@CurrentRect.ColsNumber; --rect-rows:@CurrentRect.RowsNumber;">
                        <span>@CurrentRect.RowsNumber×@CurrentRect.ColsNumber</span>
                    </div>
                }
            </div>
        </section>
    </main>
</div>
